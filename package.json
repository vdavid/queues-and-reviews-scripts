{
  "name": "queues-and-reviews-scripts",
  "version": "1.0.0",
  "description": "Automates common tasks around my Queues and Reviews sheet in Google Sheets",
  "main": "Code.ts",
  "author": "David Veszelovszki",
  "license": "MIT",
  "private": false,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "typecheck": "tsc --noEmit",
    "build": "node build.mjs",
    "push": "pnpm run build && clasp push -f",
    "deploy": "pnpm run build && clasp push -f && clasp deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest .*test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^2.0.11",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "esbuild": "^0.28.1",
    "esbuild-gas-plugin": "^0.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ban": "^2.0.0",
    "eslint-plugin-etc": "^2.0.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.4.2",
    "prettier": "^3.9.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "pnpm": ">=11"
  }
}
